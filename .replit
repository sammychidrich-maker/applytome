run = "cd backend && npm install && npx prisma generate && cd ../frontend && npm install && npm run build && cd ../backend && npx tsx src/index.ts"
entrypoint = "backend/src/index.ts"
hidden = [".config", "package-lock.json", "node_modules", "backend/node_modules", "frontend/node_modules", "backend/dev.db", "backend/dev.db-journal"]

[nix]
channel = "stable-22_11"

[env]
NODE_ENV = "production"
JWT_SECRET = "applytome-replit-secret-2024"
DATABASE_URL = "file:./dev.db"

[deployment]
build = ["sh", "-c", "cd backend && npm install && npx prisma generate && cd ../frontend && npm install && npm run build"]
run = ["sh", "-c", "cd backend && npx prisma migrate deploy && npx tsx src/index.ts"]
deploymentTarget = "cloudrun"
